# Test environment variables
DEBUG=True
TESTING=True
LOG_LEVEL=DEBUG

# Test database
DATABASE_URL=sqlite:///test_amamessage.db

# Test API keys (use fake values for tests)
TWILIO_ACCOUNT_SID=test_account_sid
TWILIO_AUTH_TOKEN=test_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Test modem configuration
TEST_MODEM_PORT=COM99
TEST_MODEM_BAUDRATE=115200

# Test SMS configuration  
TEST_SMS_FROM=+1234567890
TEST_SMS_TO=+0987654321

# Test USSD configuration
TEST_USSD_CODE=*100#
TEST_USSD_TIMEOUT=30

# Test alerting (disabled for tests)
ALERT_EMAIL_ENABLED=False
ALERT_WEBHOOK_ENABLED=False

# Test queue configuration
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# Test cloud configuration
CLOUD_TEST_ENDPOINT=https://test-api.amamessage.com
CLOUD_PROD_ENDPOINT=https://api.amamessage.com

# Test mobile configuration
MOBILE_TEST_DEVICE_ID=test-device-123
MOBILE_TEST_VERSION=1.0.0

# Test security
SECRET_KEY=test-secret-key-never-use-in-production
JWT_SECRET_KEY=test-jwt-secret-key
